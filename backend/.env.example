# 服务配置
PORT=3000
NODE_ENV=development

# 数据库配置 (Supabase / PostgreSQL)
DB_HOST=
DB_PORT=5432
DB_NAME=gamecolla
DB_USER=postgres
DB_PASSWORD=

# Redis 配置（可选，当前未实际使用）
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT 配置
JWT_SECRET=gamecolla_prod_jwt_secret_2026
JWT_EXPIRES_IN=7d

# GitHub API 配置（用于 Git 仓库管理）
# 获取方式: GitHub → Settings → Developer settings → Personal access tokens → Fine-grained tokens (或 classic token)
GITHUB_TOKEN=your_github_personal_access_token_here
GITHUB_USERNAME=your_github_username_here

# CORS 配置（生产环境改为前端实际域名）
CORS_ORIGIN=*
